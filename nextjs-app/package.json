{
  "name": "nextjs-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "db:migrate:remote": "wrangler d1 execute fomawebsitedatabase --file=migrations/0001_initial_schema.sql --remote",
    "db:migrate:local": "wrangler d1 execute fomawebsitedatabase --file=migrations/0001_initial_schema.sql --local"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "next": "15.5.20",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sanitize-html": "^2.17.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "@opennextjs/cloudflare": "^1.20.1",
    "@types/node": "^20",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "15.5.20",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "wrangler": "^4.107.0"
  },
  "overrides": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3"
  }
}
