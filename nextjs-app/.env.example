# Copy to .env.local for local development. Never commit real values.

# Public base URL for serving R2 images (custom domain or r2.dev public
# bucket URL). Optional — lib/r2.ts falls back to a same-origin route.
NEXT_PUBLIC_R2_PUBLIC_URL=

# Stripe (wired up in a later step — placeholders only)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
