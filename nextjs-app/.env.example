# Copy to .env.local for local development. Never commit real values.

# Canonical site origin for metadata, sitemap and emails. Defaults to the
# workers.dev URL in lib/site.ts; set to https://fomafamilyllc.com at cutover.
NEXT_PUBLIC_SITE_URL=

# Resend — transactional email (order confirmations). Not wired yet;
# lib/email.ts no-ops with a warning when this is empty.
RESEND_API_KEY=
# Optional From override; defaults to "FomaFamily <orders@fomafamilyllc.com>".
RESEND_FROM_EMAIL=

# Public base URL for serving R2 images (custom domain or r2.dev public
# bucket URL). Optional — lib/r2.ts falls back to a same-origin route.
NEXT_PUBLIC_R2_PUBLIC_URL=

# Shared password guarding /admin (HTTP Basic Auth in middleware.ts).
# Locally: put a value in .dev.vars (gitignored). In production: set as a
# Workers secret (npx wrangler secret put ADMIN_PASSWORD).
ADMIN_PASSWORD=

# Stripe (wired up in a later step — placeholders only)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Analytics (all optional — components render nothing when empty) ──────────

# Google Tag Manager container id (e.g. GTM-XXXXXXX). Loaded only after the
# visitor accepts the cookie banner; Consent Mode v2 defaults are set to
# denied before the container boots.
NEXT_PUBLIC_GTM_ID=

# Meta (Facebook) Pixel id. Consent-gated like GTM. Placeholder only —
# never commit a real pixel id.
NEXT_PUBLIC_META_PIXEL_ID=

# Cloudflare Web Analytics beacon token (dashboard → Analytics & Logs →
# Web Analytics → Add a site → copy the token). Cookieless, consent-exempt.
NEXT_PUBLIC_CF_BEACON_TOKEN=

# GA4 Measurement Protocol — server-side purchase events from the Stripe
# webhook (see ANALYTICS-INTEGRATION.md § purchase). Secrets: set with
# `npx wrangler secret put` in production, .dev.vars locally.
GA4_MEASUREMENT_ID=
GA4_API_SECRET=
