# Copy to .env.local for local development. Never commit real values.

# Canonical site origin for metadata, sitemap and emails. Defaults to the
# workers.dev URL in lib/site.ts; set to https://fomafamilyllc.com at cutover.
NEXT_PUBLIC_SITE_URL=

# Resend — transactional email (order confirmations). Not wired yet;
# lib/email.ts no-ops with a warning when this is empty.
RESEND_API_KEY=
# Optional From override; defaults to "FomaFamily <orders@fomafamilyllc.com>".
RESEND_FROM_EMAIL=

# Public base URL for serving R2 images (custom domain or r2.dev public
# bucket URL). Optional — lib/r2.ts falls back to a same-origin route.
NEXT_PUBLIC_R2_PUBLIC_URL=

# Shared password guarding /admin (HTTP Basic Auth in middleware.ts).
# Locally: put a value in .dev.vars (gitignored). In production: set as a
# Workers secret (npx wrangler secret put ADMIN_PASSWORD).
ADMIN_PASSWORD=

# Stripe (wired up in a later step — placeholders only)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
